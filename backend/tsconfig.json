{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "lib": ["es2022", "dom"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./",
    "resolveJsonModule": true,
    "typeRoots": ["./node_modules/@types", "./src/types"]
  },
  "include": ["src/**/*", "seed.ts"],
  "exclude": [
    "src/test-api.ts",
    "src/test-jwt-mongo.ts",
    "src/test-llm.ts",
    "whatsapp-test.js",
    "node_modules"
  ]
}
